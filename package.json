{
  "name": "worktree-colors-theme-3000",
  "displayName": "Worktree Colors Theme 3000",
  "description": "Automatically assigns unique color themes to different git worktree directories",
  "version": "0.0.1",
  "publisher": "punzar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/punzar/worktree-colors-theme-3000"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "worktree",
    "git",
    "color",
    "theme"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Worktree Colors",
      "properties": {
        "worktreeColors.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable worktree color customization"
        },
        "worktreeColors.saturation": {
          "type": "number",
          "default": 0.4,
          "minimum": 0,
          "maximum": 1,
          "description": "Color saturation (0-1)"
        },
        "worktreeColors.lightness": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Color lightness for dark themes (0-1)"
        },
        "worktreeColors.lightnessLight": {
          "type": "number",
          "default": 0.85,
          "minimum": 0,
          "maximum": 1,
          "description": "Color lightness for light themes (0-1)"
        },
        "worktreeColors.colorizeNonWorktree": {
          "type": "boolean",
          "default": false,
          "description": "Also colorize regular (non-worktree) git repositories"
        },
        "worktreeColors.colorTargets": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["titleBar", "activityBar", "statusBar"],
          "description": "Which UI elements to colorize"
        }
      }
    },
    "commands": [
      {
        "command": "worktreeColors.refresh",
        "title": "Worktree Colors: Refresh"
      },
      {
        "command": "worktreeColors.reset",
        "title": "Worktree Colors: Reset"
      },
      {
        "command": "worktreeColors.randomize",
        "title": "Worktree Colors: Randomize"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "pretest": "npm run compile && tsc -p tsconfig.test.json",
    "test": "mocha 'out/test/unit/**/*.test.js' --ui tdd --timeout 10000",
    "test:vscode": "node out/test/runTest.js",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.11",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  }
}
